# ---- Convex ----
# Get these by running: npx convex dev
# Convex will create a project and auto-populate your .env.local.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
# Optional server-only override. Leave commented for local Vite dev; the server
# falls back to VITE_CONVEX_URL, and Convex CLI warns if both active URL vars exist.
# CONVEX_URL=

# ---- Sendblue (iMessage bridge) ----
# Sign up at https://sendblue.com, get your API keys + provisioned number.
# Webhook URL you'll set in Sendblue dashboard:  <PUBLIC_URL>/sendblue/webhook
#
# SENDBLUE_FROM_NUMBER MUST be your Sendblue-provisioned number (the one
# people text TO), not your personal cell. Sendblue's API requires it.
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=

# ---- Agent runtime ----
# claude = Claude Agent SDK / Claude Code path. codex = local `codex app-server`
# path using the ChatGPT/Codex account from `codex login`.
BOOP_RUNTIME=claude

# ---- Claude model ----
# Uses your Claude Code subscription automatically — no separate API key needed.
# Override with ANTHROPIC_API_KEY if you want to bypass the subscription.
# This is the *fallback*; runtime overrides set via the iMessage set_model tool
# (stored in the Convex `settings` table) take precedence.
BOOP_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ---- Codex model ----
# Used when BOOP_RUNTIME=codex or the runtime setting is switched to Codex.
# Requires `codex login` on the host. BOOP_CODEX_AUTH_HOME can point at another
# Codex home containing auth.json if needed.
BOOP_CODEX_MODEL=gpt-5.5
BOOP_CODEX_REASONING_EFFORT=medium
# BOOP_CODEX_AUTH_HOME=

# ---- Local browser use ----
# Patchright-backed Chrome profile for login-required services, visual browser
# workflows, and bot-wall-sensitive sites. Debug UI settings stored in Convex
# take precedence over these fallbacks. Off by default; enable in Settings
# before agents can see or use the local browser integration.
# BOOP_BROWSER_ENABLED=false
# BOOP_BROWSER_PROFILE_DIR=~/.boop/browser-profile
# BOOP_BROWSER_SHOW_UI=true
# BOOP_BROWSER_LOGIN_HANDOFF=false
# BOOP_BROWSER_START_URL=
# BOOP_BROWSER_CHANNEL=chrome
# BOOP_BROWSER_EXECUTABLE_PATH=
# BOOP_BROWSER_EXTRA_ARGS=

# ---- Apple data (optional) ----
# Read-only iMessage / Apple Notes / Apple Calendar / Apple Reminders access
# on the local Mac. iMessage requires Full Disk Access for the terminal/Codex
# app running `npm run dev`. Apple Notes and Apple Reminders require macOS
# Automation permission. Calendar requires the optional Apple bridge.
# BOOP_APPLE_ENABLED=false
# BOOP_APPLE_MESSAGES_ENABLED=false
# BOOP_APPLE_NOTES_ENABLED=false
# BOOP_APPLE_REMINDERS_ENABLED=false

# ---- Proactive email surfacing ----
# Phone number that receives proactive iMessage notices when the Gmail watcher
# decides an inbound email is worth surfacing. Single-user assumption for v1.
# Without this, the webhook still registers but notices are dropped.
BOOP_USER_PHONE=
# Set to "false" to skip auto-registering the Composio webhook URL on each
# `npm run dev`. Use when you want to manage the subscription manually.
# COMPOSIO_AUTO_WEBHOOK=

# ---- Upgrade notifications ----
# On `npm run dev`, Boop checks your `upstream` remote for new commits and
# prints a banner with the commit count + a reminder to run `/upgrade-boop`.
# Set to `false` to silence the check entirely.
# BOOP_UPSTREAM_CHECK=true

# ---- Embeddings (optional — paid providers for memory recall) ----
# Tried in order: Voyage → OpenAI → local Transformers.js (Xenova/bge-large-
# en-v1.5, 1024-dim, free, ~440MB one-time download). Leave both blank to
# use the local fallback. All three produce 1024-dim vectors so the Convex
# index stays compatible regardless of which is active.
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ---- Server ----
PORT=3456

# Public URL for your server.
# - Leave as http://localhost:3456 if you're using free ngrok (URL changes each restart).
# - Set to your stable public URL (e.g. https://boop.mydomain.com) if you use
#   Cloudflare Tunnel, a Caddy server, or any other tunnel with a fixed URL —
#   `npm run dev` will then skip ngrok.
PUBLIC_URL=http://localhost:3456

# Optional: ngrok RESERVED domain (paid plan). Example: "boop.ngrok.app".
# When set, `npm run dev` launches ngrok with --domain=$NGROK_DOMAIN so your
# public URL stays the same across restarts.
# NGROK_DOMAIN=

# When free-plan ngrok is in use, `npm run dev` auto-registers the new tunnel
# URL with Sendblue as the inbound (receive) webhook so you don't have to
# paste it into the dashboard. Set to "false" to disable this behavior.
# SENDBLUE_AUTO_WEBHOOK=true

# ---- Composio (1000+ integrations, zero-code) ----
# Get an API key at https://app.composio.dev/developers.
# Once set, connect toolkits (Gmail, Slack, GitHub, Linear, …) from the
# Debug UI's Connections tab. Each connected toolkit becomes available to
# the agent via spawn_agent(integrations: [...]).
COMPOSIO_API_KEY=

# Optional: stable user id Composio keys connections under. Defaults to
# "boop-default". Override only if you already manage Composio sessions
# elsewhere and want Boop to reuse that user.
# COMPOSIO_USER_ID=

# --- Image retention (optional) ---
# Days to keep iMessage-received image bytes. Images referenced by a
# memory record are kept indefinitely regardless of this setting.
# Set to 0 to disable cleanup (debug only).
BOOP_IMAGE_RETENTION_DAYS=3
BOOP_IMAGE_CLEANUP_INTERVAL_MS=43200000
